generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  steamId       String    @unique
  username      String
  avatar        String
  profileUrl    String
  leetifyToken  String?
  cs2Elo        Int?
  balance       Int       @default(10000)
  discordId     String?   @unique
  createdAt     DateTime  @default(now())
  clips           Clip[]
  clipLikes       ClipLike[]
  gameVotes       GameVote[]
  gameRequests    GameRequest[]
  chatMessages    ChatMessage[]
  seasonSnapshots SeasonSnapshot[]
  createdSessions GamingSession[] @relation("CreatedSessions")
  sessionRsvps    SessionRsvp[]
  achievements    Achievement[]
  notifications   Notification[]
  clipVotes       ClipVote[]
  userItems          UserItem[]
  sellerListings     MarketListing[]     @relation("SellerListings")
  buyerPurchases     MarketListing[]     @relation("BuyerPurchases")
  voiceRewards       VoiceReward[]
  linkCode           DiscordLinkCode?
  userCases          UserCase[]
  caseSellerListings CaseMarketListing[] @relation("CaseSeller")
  caseBuyerPurchases CaseMarketListing[] @relation("CaseBuyer")
}

model DiscordLinkCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model VoiceReward {
  id        String   @id @default(cuid())
  userId    String
  coins     Int
  minutes   Int
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CaseItem {
  id        String          @id
  name      String
  rarity    String
  color     String
  emoji     String
  sellValue Int
  weight    Int
  imageUrl  String?
  userItems UserItem[]
  listings  MarketListing[]
}

model UserItem {
  id         String         @id
  userId     String
  itemId     String
  sold       Boolean        @default(false)
  float      Float?
  obtainedAt DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id])
  item       CaseItem       @relation(fields: [itemId], references: [id])
  listing    MarketListing?
}

model MarketListing {
  id         String    @id
  sellerId   String
  userItemId String    @unique
  itemId     String
  price      Int
  status     String    @default("active")
  buyerId    String?
  createdAt  DateTime  @default(now())
  soldAt     DateTime?
  seller     User      @relation("SellerListings", fields: [sellerId], references: [id])
  buyer      User?     @relation("BuyerPurchases", fields: [buyerId], references: [id])
  userItem   UserItem  @relation(fields: [userItemId], references: [id])
  item       CaseItem  @relation(fields: [itemId], references: [id])
}

model CaseType {
  id          String              @id @default(cuid())
  name        String
  description String?
  imageEmoji  String              @default("📦")
  imageUrl    String?
  price       Int
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  userCases   UserCase[]
  listings    CaseMarketListing[]
}

model UserCase {
  id         String             @id @default(cuid())
  userId     String
  caseTypeId String
  opened     Boolean            @default(false)
  obtainedAt DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id])
  caseType   CaseType           @relation(fields: [caseTypeId], references: [id])
  listing    CaseMarketListing?
}

model CaseMarketListing {
  id         String    @id @default(cuid())
  sellerId   String
  userCaseId String    @unique
  caseTypeId String
  price      Int
  status     String    @default("active")
  buyerId    String?
  createdAt  DateTime  @default(now())
  soldAt     DateTime?
  seller     User      @relation("CaseSeller", fields: [sellerId], references: [id])
  buyer      User?     @relation("CaseBuyer", fields: [buyerId], references: [id])
  userCase   UserCase  @relation(fields: [userCaseId], references: [id])
  caseType   CaseType  @relation(fields: [caseTypeId], references: [id])
}

model GamingSession {
  id          String        @id @default(cuid())
  title       String
  game        String
  scheduledAt DateTime
  createdById String
  createdBy   User          @relation("CreatedSessions", fields: [createdById], references: [id])
  rsvps       SessionRsvp[]
  createdAt   DateTime      @default(now())
}

model SessionRsvp {
  id        String        @id @default(cuid())
  sessionId String
  userId    String
  status    String
  session   GamingSession @relation(fields: [sessionId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([sessionId, userId])
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  type      String
  value     Float
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, type])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  refId     String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ClipVote {
  id      String @id @default(cuid())
  userId  String
  shareId String
  value   Int
  user    User   @relation(fields: [userId], references: [id])

  @@unique([userId, shareId])
}

model Clip {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  title       String
  url         String
  platform    String
  description String?
  createdAt   DateTime   @default(now())
  likes       ClipLike[]
}

model ClipLike {
  id     String @id @default(cuid())
  userId String
  clipId String
  user   User   @relation(fields: [userId], references: [id])
  clip   Clip   @relation(fields: [clipId], references: [id])

  @@unique([userId, clipId])
}

model GameRequest {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  steamAppId  String
  gameName    String
  headerImage String?
  description String?
  createdAt   DateTime   @default(now())
  votes       GameVote[]
}

model GameVote {
  id            String      @id @default(cuid())
  userId        String
  gameRequestId String
  value         Int
  user          User        @relation(fields: [userId], references: [id])
  gameRequest   GameRequest @relation(fields: [gameRequestId], references: [id])

  @@unique([userId, gameRequestId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model Season {
  id        String           @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  snapshots SeasonSnapshot[]
}

model SeasonSnapshot {
  id        String   @id @default(cuid())
  seasonId  String
  userId    String
  cs2Elo    Int?
  rank      Int
  season    Season   @relation(fields: [seasonId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([seasonId, userId])
}
